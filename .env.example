# ============================================================
# VARIABLES DE ENTORNO — ETL Violencia Intrafamiliar
# Copia este archivo como .env y rellena con tus valores reales
# NUNCA subas .env a GitHub
# ============================================================

# --- Supabase / PostgreSQL ---
DB_HOST=aws-0-us-east-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.TUPROYECTOID
DB_PASSWORD=TU_PASSWORD_AQUI

# --- Rutas del proyecto ---
# Se resuelven automáticamente desde config.py, no es necesario cambiar
# BASE_DIR se calcula como el directorio raíz del proyecto

# --- API ---
DIVIPOLA_API_URL=https://www.datos.gov.co/resource/gdxc-w37w.json
DIVIPOLA_LIMIT=5000

# --- Airflow (solo si usas Airflow) ---
AIRFLOW__CORE__DAGS_FOLDER=./dags
AIRFLOW__CORE__EXECUTOR=SequentialExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:///./airflow.db
